{
  "name": "@nshiab/journalism-dataviz",
  "version": "1.0.8",
  "exports": {
    ".": "./src/index.ts",
    "./web": "./src/web.ts"
  },
  "tasks": {
    "all-tests": "deno fmt --check && deno lint && deno check src/index.ts && deno doc --lint src/index.ts && deno publish --allow-dirty --dry-run && TZ=America/Toronto deno test -A --fail-fast && deno task llm",
    "llm": "deno doc --json src/index.ts > docs.json && deno run -A src/generateLlmMd.ts && deno fmt llm.md",
    "bundle-journalism-format": "deno bundle --platform=browser --minify src/dataviz/imports/buildJournalismFormat.ts -o src/dataviz/imports/journalism-format.js",
    "test-coverage": "deno test -A --fail-fast --coverage=cov_profile && deno coverage cov_profile",
    "patch-no-tests": "deno run -A src/incrementVersion.ts patch",
    "minor-no-tests": "deno run -A src/incrementVersion.ts minor",
    "patch": "deno task all-tests && deno run -A src/incrementVersion.ts patch",
    "minor": "deno task all-tests && deno run -A src/incrementVersion.ts minor",
    "major": "deno task all-tests && deno run -A src/incrementVersion.ts major"
  },
  "publish": {
    "exclude": [
      "test",
      ".github",
      "src/dataviz/imports/buildJournalismFormat.ts"
    ]
  },
  "nodeModulesDir": "auto",
  "imports": {
    "@nshiab/journalism-format": "jsr:@nshiab/journalism-format@^1.1.3",
    "@napi-rs/canvas": "npm:@napi-rs/canvas@^0.1.65",
    "@observablehq/plot": "npm:@observablehq/plot@^0.6.17",
    "@resvg/resvg-js": "npm:@resvg/resvg-js@^2.6.2",
    "@std/dotenv": "jsr:@std/dotenv@^0.225.6",
    "d3-array": "npm:d3-array@^3.2.4",
    "d3-dsv": "npm:d3-dsv@^3.0.1",
    "d3-geo": "npm:d3-geo@^3.1.1",
    "linkedom": "npm:linkedom@^0.18.5"
  },
  "fmt": {
    "exclude": [
      "test/output",
      "src/dataviz/imports"
    ]
  },
  "compilerOptions": {
    "lib": [
      "dom",
      "deno.ns"
    ]
  },
  "lint": {
    "include": [
      "src/**/*.ts"
    ],
    "exclude": [
      "src/dataviz/imports"
    ]
  },
  "allowScripts": [
    "npm:playwright-chromium@1"
  ]
}
